# =============================================
# ChamApp Backend — Exemplo de Variáveis
# =============================================

# --- Servidor ---
NODE_ENV=dev
PORT=3333

# --- Banco de Dados ---
DATABASE_URL="postgresql://docker:docker@localhost:5432/chamapp"

# --- JWT ---
JWT_SECRET=minimo-32-caracteres-aqui-xxxxx-xxxxxx

# --- Firebase (FCM) ---
FCM_PROJECT_ID=seu-projeto-firebase
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk@seu-projeto.iam.gserviceaccount.com

# --- Storage Backblaze B2 ---
B2_ENDPOINT=https://s3.us-west-000.backblazeb2.com
B2_REGION=us-west-000
B2_BUCKET=chamapp-uploads
B2_ACCESS_KEY_ID=sua-access-key
B2_SECRET_ACCESS_KEY=sua-secret-key
B2_PUBLIC_BASE_URL=https://f000.backblazeb2.com/file/chamapp-uploads

# --- E-mail (OTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua-senha-de-app
